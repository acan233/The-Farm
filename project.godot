;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="farm4"
run/main_scene="uid://cv8aaftdoysoo"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://ewx5xm2lj50q"

[autoload]

ToolManager="*uid://dd01r4pdai18k"
InventoryManager="*uid://bdkrp5i3yaub6"
DayAndNightCycleManager="*uid://u5mqvsouqi7x"
SaveGameManager="*uid://b0xoifedfvw6t"
DialogueManager="*uid://c3rodes2l3gxb"
GameDialogueManager="*uid://df1t2jolgj8j"
GameManager="*uid://bniu13h614sx4"
SceneManager="*uid://bpeqyhoh457pk"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="farm3"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/hasturoperationgd/plugin.cfg")

[file_customization]

folder_colors={
"res://Tilesets/": "yellow",
"res://assets/": "orange",
"res://audio/": "red",
"res://dialogue/": "blue",
"res://resources/": "purple",
"res://scenes/": "green",
"res://scripts/": "pink"
}

[global_group]

navigation_polygon_source_geometry_group=""
player=""

